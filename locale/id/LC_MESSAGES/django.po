#: Notifications/signals.py:24
msgid "Confirm your email"
msgstr "Konfirmasikan email Anda"

#: Notifications/signals.py:26
msgid ""
"Validate your email to unlock chat and community creation. If you did not "
"receive the email, open Profile Details and resend it."
msgstr ""
"Validasi email Anda untuk membuka kunci obrolan dan pembuatan komunitas. "
"Jika Anda tidak menerima email, buka Detail Profil dan kirim ulang."

#: Notifications/signals.py:42
msgid "Verify your new email"
msgstr "Verifikasi email baru Anda"

#: Notifications/signals.py:44
#, python-format
msgid ""
"You requested to change your email to %(email)s. We've sent a verification "
"link there — click it to confirm the update."
msgstr ""
"Anda meminta untuk mengubah email Anda menjadi %(email)s. Kami telah "
"mengirimkan tautan verifikasi ke sana — klik tautan tersebut untuk "
"mengonfirmasi pembaruan."

#: Notifications/signals.py:60
msgid "Email confirmed"
msgstr "Email dikonfirmasi"

#: Notifications/signals.py:61
msgid "Congratulations. Your email has been confirmed successfully."
msgstr "Selamat. Email Anda telah berhasil dikonfirmasi."

#: Notifications/signals.py:75
msgid "New join request"
msgstr "Permintaan bergabung baru"

#: Notifications/signals.py:76

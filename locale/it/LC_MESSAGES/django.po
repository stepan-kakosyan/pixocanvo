msgstr "%(username)s ha chiesto di iscriversi a %(community)s."

#: Notifications/signals.py:104
msgid "Join request approved"
msgstr "Richiesta di adesione approvata"

#: Notifications/signals.py:104
msgid "Join request declined"
msgstr "Richiesta di iscrizione rifiutata"

#: Notifications/signals.py:106
